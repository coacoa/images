@startuml
left to right direction
skinparam packageStyle rectangle

actor ユーザー

' ---------------------------
' Nix 正常フロー
' ---------------------------
node "NixOS（宣言的管理）" {
    [設定ファイル\n(configuration.nix / home.nix)]
    [ロボットA（現行）]
    [ロボットB（新構成）]

    ユーザー --> "設定ファイル\n(configuration.nix / home.nix)"
    "設定ファイル\n(configuration.nix / home.nix)" --> "ロボットB（新構成）"

    ユーザー --> "ロボットA（現行）"
    ユーザー --> "ロボットB（新構成）"
}

' ---------------------------
' 自動変更ツール
' ---------------------------
node "GUI / プラグインツール" {
    [fcitx5 設定ツール]
    [プラグイン管理ツール]
}

"fcitx5 設定ツール" --> "ロボットA（現行）"
"プラグイン管理ツール" --> "ロボットA（現行）"

' ---------------------------
' 問題発生
' ---------------------------
node "rebuildチェック" {
    [不一致検出]
}

"ロボットA（現行）" --> "不一致検出"
"設定ファイル\n(configuration.nix / home.nix)" --> "不一致検出"

"不一致検出" --> ユーザー

' ---------------------------
' 回避策
' ---------------------------
node "対策" {
    [Nixで管理\n(Home Manager)]
    [変更を許容\n(mutable設定)]
    [環境を分離\n(nix develop)]
}

ユーザー --> "Nixで管理\n(Home Manager)"
ユーザー --> "変更を許容\n(mutable設定)"
ユーザー --> "環境を分離\n(nix develop)"

' ---------------------------
' 本質
' ---------------------------
rectangle "本質\n自動変更された設定 vs 宣言的に定義された状態"

@enduml